# =============================================================================
# JUCE / C++ Bass Amp Simulator — .gitignore
# Targets: Windows (MSVC) + macOS (Clang), CMake, VST3/AU/Standalone
# =============================================================================

# -----------------------------------------------------------------------------
# Build directories
# -----------------------------------------------------------------------------
build/
Build/
Builds/
out/
cmake-build-*/

# -----------------------------------------------------------------------------
# CMake generated files
# -----------------------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
CTestTestfile.cmake
_deps/

# -----------------------------------------------------------------------------
# JUCE generated code (Projucer 사용 시 생성됨, CMake 빌드에선 불필요)
# -----------------------------------------------------------------------------
JuceLibraryCode/

# -----------------------------------------------------------------------------
# Plugin / App 빌드 산출물
# 실제 배포 바이너리는 저장소에 포함하지 않음
# -----------------------------------------------------------------------------
*.vst3
*.component
*.app
*.appex
*.aaxplugin

# -----------------------------------------------------------------------------
# 컴파일러 중간 산출물
# -----------------------------------------------------------------------------
*.o
*.obj
*.a
*.lib
*.dll
*.so
*.dylib
*.pdb
*.ilk
*.exp
*.map
*.idb

# -----------------------------------------------------------------------------
# IDE / 에디터
# CMake가 생성하는 프로젝트 파일은 재생성 가능하므로 제외
# -----------------------------------------------------------------------------
# Xcode (macOS, cmake -G Xcode 로 생성)
*.xcodeproj/
*.xcworkspace/
xcuserdata/
*.xccheckout
*.xcsettings

# Visual Studio / MSBuild (Windows, cmake -G "Visual Studio ..." 로 생성)
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
.vs/

# CLion
.idea/

# VS Code (개인 설정은 제외, 공유 설정인 .vscode/tasks.json 등은 팀 합의 후 결정)
.vscode/

# -----------------------------------------------------------------------------
# OS 생성 파일
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# 오디오 리소스
# Resources/IR/ 내의 내장 IR 파일(WAV)은 추적 대상임 (소용량 번들 IR)
# 단, 외부에서 가져오는 대용량 IR 라이브러리는 아래 패턴으로 제외
# 대용량 IR이 필요하면 Git LFS 사용 권장
# -----------------------------------------------------------------------------
/ir-library/
/third-party-ir/

# -----------------------------------------------------------------------------
# 코드 서명 / 배포 관련 민감 파일
# -----------------------------------------------------------------------------
*.p12
*.mobileprovision
entitlements.plist
*.cer
*.certSigningRequest

# -----------------------------------------------------------------------------
# 크래시 덤프 / 로그
# -----------------------------------------------------------------------------
*.dmp
*.crash
*.log
